-- Cipher Protocol: Owner-Centered Shield + Wipe + LoopSmite + Original Farm
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwners = {["banned4lag"] = true, ["ritzwitsplits"] = true}
local targetName = nil 
local running = false
local owners = {["banned4lag"] = true, ["ritzwitsplits"] = true}
local whitelist = {["banned4lag"] = true, ["ritzwitsplits"] = true} 
local smiting = false
local loopsmiting = nil
local hiding = true
local shieldRadius = 10
local shieldActive = false
local shieldOwner = nil
local sessionSlaps = 0
local annoyTarget = nil

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(100, 1, 100)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Transparency = 1
    plate.Parent = Workspace
end
createStealthPlate()

local function chatLog(text) print("[Cipher]: " .. text) end

local function findTarget(name)
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then return p end
    end
    return nil
end

local function forceReset()
    local char = player.Character
    if not char then return end
    pcall(function()
        char:BreakJoints()
        if char:FindFirstChildOfClass("Humanoid") then char:FindFirstChildOfClass("Humanoid").Health = 0 end
    end)
end

-- COMBAT: 100K PREDICTIVE SMITE
local function executeSmite(targetP, duration)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(100000, 100000, 100000)
            myHRP.RotVelocity = Vector3.new(0, 100000, 0)
        end)
        
        local strikeEnd = tick() + (duration or 5)
        local side = 1
        
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            local prediction = tHRP.Position + (tHRP.Velocity * 0.12)
            side = side * -1
            myChar:PivotTo(CFrame.new(prediction + (tHRP.CFrame.LookVector * (side * 6)), prediction))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myHRP.RotVelocity = Vector3.zero
        smiting = false
    end
end

-- WIPE LOGIC
local function startWipe()
    chatLog("Wiping Server...")
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and not whitelist[p.Name:lower()] then
            executeSmite(p, 3)
            task.wait(0.1)
        end
    end
end

-- ANNOY LOGIC
local function startAnnoy(targetP)
    if not targetP or not targetP.Character then return end
    
    local stick = Workspace:FindFirstChild("Lobby") and Workspace.Lobby:FindFirstChild("Stick")
    if not stick then chatLog("Stick not found!") return end
    
    while annoyTarget == targetP.Name and targetP.Character do
        local myChar = player.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local tChar = targetP.Character
        local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
        local ragdoll = tChar and tChar:FindFirstChild("Ragdolled")
        
        if myChar and myHRP and tChar and tHRP and ragdoll then
            if ragdoll.Value == false then
                -- Teleport 10 studs below player
                myHRP.CFrame = tHRP.CFrame * CFrame.new(0, -10, 0)
                task.wait(0.8)
                
                -- Click stick via ClickDetector
                pcall(function()
                    local clickDet = stick:FindFirstChild("ClickDetector")
                    if clickDet then
                        fireclickdetector(clickDet)
                    end
                end)
                
                task.wait(0.8)
                
                -- Hit with GeneralHit
                pcall(function()
                    local hitRemote = game:GetService("ReplicatedStorage"):FindFirstChild("GeneralHit")
                    if hitRemote then
                        local hitPart = tChar:FindFirstChild("Torso") or tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChildOfClass("BasePart")
                        if hitPart then
                            hitRemote:FireServer(hitPart)
                        end
                    end
                end)
                
                -- Teleport back to stealth
                task.wait(1)
                myHRP.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
            end
        end
        task.wait(1)
    end
    chatLog("Stopped annoying " .. targetP.Name)
end

-- DYNAMIC SHIELD (Centered on Command Runner)
task.spawn(function()
    while true do
        if shieldActive and shieldOwner and not smiting then
            local sChar = shieldOwner.Character
            local sHRP = sChar and sChar:FindFirstChild("HumanoidRootPart")
            
            if sHRP then
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p ~= shieldOwner and not whitelist[p.Name:lower()] then
                        local tChar = p.Character
                        local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
                        if tHRP and (tHRP.Position - sHRP.Position).Magnitude <= shieldRadius then
                            executeSmite(p, 2)
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

-- MAIN ENGINE (FARM LOGIC)
task.spawn(function()
    while true do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if loopsmiting and not smiting then
            local t = Players:FindFirstChild(loopsmiting)
            if t then 
                executeSmite(t, 4) 
            else 
                loopsmiting = nil 
            end
            
        elseif running and targetName and not smiting then
            -- Only proceed if we have a valid character
            if not (char and hum and hrp and hum.Health > 0) then
                task.wait(0.5)
                continue
            end
            
            pcall(function()
                -- Get target
                local t = Players:FindFirstChild(targetName)
                if not t or not t.Character then
                    return
                end
                
                local tChar = t.Character
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                if not tHRP then
                    return
                end
                
                -- Check if target is in arena
                local isInArena = tChar:FindFirstChild("isInArena")
                if not isInArena or not isInArena.Value then
                    -- Target not in arena, try to go through portal
                    local portal = Workspace:FindFirstChild("Arena") and Workspace.Arena:FindFirstChild("Portal")
                    if portal then
                        chatLog("Entering arena...")
                        hrp.CFrame = portal.CFrame + portal.CFrame.LookVector * 5
                        task.wait(0.8)
                        hrp.CFrame = portal.CFrame
                        task.wait(1.5)
                    end
                    return
                end
                
                -- Teleport to starting position in arena
                local startPos = CFrame.new(-1210, 328, -8)
                hrp.CFrame = startPos
                task.wait(0.2)
                
                -- Get fresh target reference
                t = Players:FindFirstChild(targetName)
                if not t or not t.Character then return end
                tChar = t.Character
                tHRP = tChar:FindFirstChild("HumanoidRootPart")
                if not tHRP then return end
                
                -- Teleport to target
                char:PivotTo(tHRP.CFrame * CFrame.new(0, 1.5, -3))
                task.wait(0.15)
                
                -- Wait for hit to register (reduced timeout)
                local hitStart = tick()
                local hit = false
                repeat 
                    -- Check if target is ragdolled
                    local rag = tChar:FindFirstChild("Ragdolled")
                    if rag and rag.Value then
                        hit = true
                        sessionSlaps = sessionSlaps + 1
                    end
                    
                    -- Check if target velocity is high (took damage)
                    if tHRP and tHRP.Velocity.Magnitude > 20 then
                        hit = true
                        sessionSlaps = sessionSlaps + 1
                    end
                    
                    task.wait(0.02)
                until hit or tick() - hitStart > 1 or not running
                
                -- Reset character immediately
                if char and char.Parent then
                    forceReset()
                    -- Wait for respawn (faster)
                    local respawnStart = tick()
                    repeat task.wait(0.05) until player.Character ~= char or tick() - respawnStart > 3 or not running
                    task.wait(0.1)
                end
            end)
            task.wait(0.05)
            
        else
            -- Hide in stealth position
            if hiding and hrp and (hrp.Position - stealthPos).Magnitude > 100 and not smiting then
                hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
            end
            task.wait(0.1)
        end
    end
end)

-- COMMAND HANDLER
local function processChat(msg, speaker)
    local sUser = speaker.Name:lower()
    if not owners[sUser] then return end
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then running = true
    elseif cmd == ".stop" then running = false
    elseif cmd == ".wipe" then task.spawn(startWipe)
    elseif cmd == ".shield" then
        if args[2] == "off" then
            shieldActive = false
            chatLog("Shield Disabled.")
        else
            shieldRadius = tonumber(args[2]) or 10
            shieldOwner = speaker
            shieldActive = true
            chatLog("Shield active on " .. speaker.Name .. " (" .. shieldRadius .. " studs)")
        end
    elseif cmd == ".target" and args[2] then
        local p = findTarget(args[2])
        if p then targetName = p.Name end
    elseif cmd == ".smite" and args[2] then
        local p = findTarget(args[2])
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".loopsmite" and args[2] then
        local p = findTarget(args[2])
        if p and not whitelist[p.Name:lower()] then loopsmiting = p.Name end
    elseif cmd == ".unloopsmite" then loopsmiting = nil
    elseif cmd == ".addowner" and args[2] then
        local p = findTarget(args[2])
        if p then 
            owners[p.Name:lower()] = true
            chatLog(p.Name .. " added to owners.")
        end
    elseif cmd == ".removeowner" and args[2] then
        local p = findTarget(args[2])
        if p then 
            owners[p.Name:lower()] = nil
            chatLog(p.Name .. " removed from owners.")
        end
    elseif cmd == ".annoy" and args[2] then
        local p = findTarget(args[2])
        if p then
            annoyTarget = p.Name
            chatLog("Annoying " .. p.Name .. ". Use .unannoy to stop.")
            task.spawn(startAnnoy, p)
        end
    elseif cmd == ".unannoy" then
        if annoyTarget then
            chatLog("Stopped annoying.")
            annoyTarget = nil
        end
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then forceReset() end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

chatLog("Shield Update Applied. Center is now the Command Runner.")
