-- Cipher Protocol: Unified Suite (Stability Priority)
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwner = "rizalakasa"
local targetName = nil 
local running = false
local owners = { [primaryOwner:lower()] = true }
local whitelist = { [primaryOwner:lower()] = true } 
local smiting = false
local loopsmiting = nil
local hiding = true
local sessionSlaps = 0

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(100, 1, 100)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Parent = Workspace
end
createStealthPlate()

local function chatLog(text) print("[Cipher]: " .. text) end

local function findTarget(name)
    if not name then return nil end
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then return p end
    end
    return nil
end

local function forceReset()
    local char = player.Character
    if not char then return end
    pcall(function()
        char:BreakJoints()
        if char:FindFirstChildOfClass("Humanoid") then
            char:FindFirstChildOfClass("Humanoid").Health = 0
        end
    end)
end

-- COMBAT: SMITE ENGINE (Fixed 5s Loop)
local function executeSmite(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(50000, 50000, 50000)
        end)
        
        local strikeEnd = tick() + 5
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 2))
            RunService.Heartbeat:Wait()
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -2))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

-- MAIN FARM ENGINE (Standard Teleport + Lobby Sync)
task.spawn(function()
    while true do
        task.wait(0.1)
        
        if loopsmiting and not smiting then
            local t = Players:FindFirstChild(loopsmiting)
            if t then executeSmite(t) else loopsmiting = nil end
        elseif running and targetName and not smiting then
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if hrp and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health > 0 then
                -- 1. Portal Move
                hrp.CFrame = CFrame.new(-1210, 328, -8)
                
                -- Wait for Arena Drop (Y-Check)
                local syncWait = tick()
                repeat task.wait() until (hrp.Position.Y < 200) or (tick() - syncWait > 1.5)
                
                local t = Players:FindFirstChild(targetName)
                local tHRP = t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                
                if tHRP and hrp.Position.Y < 200 then
                    -- 2. Target Move
                    hrp.CFrame = tHRP.CFrame * CFrame.new(0, 0, -3.5)
                    
                    -- Slap Watchdog
                    local startW = tick()
                    local hit = false
                    repeat 
                        local rag = Workspace:FindFirstChild("bp1frms") and Workspace.bp1frms:FindFirstChild("Ragdolled")
                        if (rag and rag.Value) or (tHRP.Velocity.Magnitude > 20) then
                            hit = true
                            sessionSlaps = sessionSlaps + 1
                        end
                        RunService.Heartbeat:Wait()
                    until hit or tick() - startW > 1.2 or not running
                    
                    forceReset()
                    repeat task.wait() until player.Character ~= char or not running
                    task.wait(0.3)
                else
                    forceReset() -- Stuck in lobby, reset to try again
                end
            end
        end
    end
end)

-- COMMAND HANDLER (Owners + Smite Restored)
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] then return end
    
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    -- FARMING
    if cmd == ".farm" then running = true chatLog("Farm ON.")
    elseif cmd == ".stop" then running = false chatLog("Farm OFF.")
    elseif cmd == ".target" and args[2] then
        local p = findTarget(args[2])
        if p then targetName = p.Name chatLog("Locked: "..p.Name) end
    
    -- COMBAT
    elseif cmd == ".smite" and args[2] then
        local p = findTarget(args[2])
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".loopsmite" and args[2] then
        local p = findTarget(args[2])
        if p then loopsmiting = p.Name chatLog("Loop Smite: "..p.Name) end
    elseif cmd == ".unloopsmite" then loopsmiting = nil
    
    -- OWNER MANAGEMENT
    elseif cmd == ".addowner" and args[2] then
        local p = findTarget(args[2])
        if p then 
            owners[p.Name:lower()] = true 
            chatLog("Added Owner: "..p.Name)
        end
    elseif cmd == ".removeowner" and args[2] then
        local name = args[2]:lower()
        if owners[name] and name ~= primaryOwner:lower() then
            owners[name] = nil
            chatLog("Removed Owner: "..name)
        end
    
    -- UTILITY
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then forceReset()
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

-- STEALTH IDLE
RunService.Heartbeat:Connect(function()
    if not running and not smiting then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - stealthPos).Magnitude > 200 then
            hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
        end
    end
end)

chatLog("Full Cipher Suite Restored. Smite & Owner modules active.")
