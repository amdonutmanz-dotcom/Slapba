-- Cipher Protocol: Utility Expansion Patch
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true
}
local smiting = false

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
end

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

local function forceReset(hum, char)
    if not hum or not char then return end
    pcall(function()
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
        hum:ChangeState(Enum.HumanoidStateType.Dead)
    end)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName and not smiting then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    if myHRP then myHRP.CFrame = CFrame.new(-1210, 328, 4) end
                    task.wait(0.4)

                    if smiting then return end

                    for i = 1, 5 do
                        if not running or smiting or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and not smiting and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    if running and not smiting and humanoid and humanoid.Parent then
                        forceReset(humanoid, char)
                        player.CharacterAdded:Wait()
                        task.wait(0.6)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    local sDisplay = speaker.DisplayName:lower()

    if not owners[sName] and not owners[sDisplay] then return end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        running = true chatLog("Loop Resumed.")
    elseif cmd == ".stop" then
        running = false chatLog("Loop Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target Locked: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Owner Added: " .. p.Name)
                break
            end
        end
    elseif cmd == ".removeowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                if p.Name:lower() ~= "rizalakasa" then
                    owners[p.Name:lower()] = nil
                    chatLog("Owner Removed: " .. p.Name)
                else
                    chatLog("Cannot remove primary owner.")
                end
                break
            end
        end
    elseif cmd == ".reset" then
        chatLog("Resetting bot...")
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        forceReset(hum, char)
    elseif cmd == ".rejoin" or cmd == ".rj" then
        chatLog("Rejoining...")
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".smite" and args[2] then
        local smiteTarget = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                smiteTarget = p
                break
            end
        end
        
        if smiteTarget then
            task.spawn(function()
                smiting = true
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then
                    chatLog("Bot loading...")
                    player.CharacterAdded:Wait()
                    char = player.Character
                    hum = char:WaitForChild("Humanoid")
                    task.wait(0.2)
                end

                local hrp = getHRP(char)
                local tChar = smiteTarget.Character
                local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
                
                if hrp and tHRP and hum then
                    local originalPos = hrp.CFrame
                    chatLog("Smite Active: " .. smiteTarget.Name)

                    hrp.CanCollide = false
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                    
                    local flingLoop = RunService.Heartbeat:Connect(function()
                        local vel = hrp.Velocity
                        hrp.Velocity = vel * 99999999 + Vector3.new(0, 99999999, 0)
                        RunService.RenderStepped:Wait()
                        hrp.Velocity = vel
                        RunService.Stepped:Wait()
                        hrp.Velocity = vel + Vector3.new(0, 0.1, 0)
                    end)

                    local endTime = tick() + 4
                    local toggle = true
                    while tick() < endTime do
                        if tHRP and tHRP.Parent then
                            toggle = not toggle
                            local prediction = tHRP.Velocity * 0.22
                            local jitter = toggle and 2 or -2
                            local targetPos = tHRP.Position + prediction
                            hrp.CFrame = CFrame.new(targetPos) * CFrame.new(jitter, 0, jitter)
                        else
                            break 
                        end
                        RunService.Heartbeat:Wait()
                    end

                    flingLoop:Disconnect()
                    hrp.Velocity = Vector3.zero
                    hrp.CFrame = originalPos
                    smiting = false
                    chatLog("Smite Complete.")
                else
                    smiting = false
                    chatLog("Smite Failed.")
                end
            end)
        end
    end
end

-- HOOKS
local function connect(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end

for _, p in pairs(Players:GetPlayers()) do connect(p) end
Players.PlayerAdded:Connect(connect)

chatLog("Cipher Active. Utility Commands Loaded.")
