-- Cipher Protocol: Anchored Sky-Stall Module
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true
}
local smiting = false
local annoying = false

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
end

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

local function stopVelocity(hrp)
    if hrp then
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
    end
end

local function forceReset(hum, char)
    if not hum or not char then return end
    pcall(function()
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
        hum:ChangeState(Enum.HumanoidStateType.Dead)
    end)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        stopVelocity(myHRP)
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName and not smiting and not annoying then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    if myHRP then 
                        stopVelocity(myHRP)
                        myHRP.CFrame = CFrame.new(-1210, 328, 4) 
                    end
                    task.wait(0.4)

                    if smiting or annoying then return end

                    for i = 1, 5 do
                        if not running or smiting or annoying or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and not smiting and not annoying and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    if running and not smiting and not annoying and humanoid and humanoid.Parent then
                        forceReset(humanoid, char)
                        player.CharacterAdded:Wait()
                        task.wait(0.6)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    local sDisplay = speaker.DisplayName:lower()

    if not owners[sName] and not owners[sDisplay] then return end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Owner Added: " .. p.Name)
                break
            end
        end
    elseif cmd == ".removeowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                if p.Name:lower() ~= "rizalakasa" then
                    owners[p.Name:lower()] = nil
                    chatLog("Owner Removed: " .. p.Name)
                else
                    chatLog("Cannot remove primary owner.")
                end
                break
            end
        end
    elseif cmd == ".start" then
        running = true chatLog("Loop Resumed.")
    elseif cmd == ".stop" then
        running = false chatLog("Loop Stopped.")
    elseif cmd == ".reset" then
        local char = player.Character
        forceReset(char:FindFirstChildOfClass("Humanoid"), char)
    elseif cmd == ".rejoin" or cmd == ".rj" then
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target Locked: " .. targetName)
                break
            end
        end

    -- ANCHORED ANNOY SEQUENCE
    elseif cmd == ".annoy" and args[2] then
        local annoyTarget = nil
        local count = tonumber(args[3]) or 1
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                annoyTarget = p
                break
            end
        end
        
        if annoyTarget then
            task.spawn(function()
                annoying = true
                local char = getCharacter(player)
                local hrp = getHRP(char)
                local hum = char:FindFirstChildOfClass("Humanoid")
                
                if hrp and hum then
                    -- Physics Lockdown
                    hum.PlatformStand = true
                    stopVelocity(hrp)
                    
                    -- Initial Portal Fetch
                    hrp.CFrame = CFrame.new(-1210, 328, -7)
                    task.wait(0.4)

                    for i = 1, count do
                        if not annoying then break end
                        
                        local tool = player.Backpack:FindFirstChildOfClass("Tool") or char:FindFirstChildOfClass("Tool")
                        local tChar = annoyTarget.Character
                        local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
                        
                        if tHRP and tool then
                            tool.Parent = char
                            stopVelocity(hrp)
                            
                            -- Strike Teleport
                            hrp.CFrame = tHRP.CFrame * CFrame.new(0, 0, 3)
                            task.wait(0.05)
                            tool:Activate()
                            
                            -- Delay to hit
                            task.wait(0.4)
                            
                            -- Vanish to Sky
                            stopVelocity(hrp)
                            hrp.CFrame = CFrame.new(hrp.Position.X, 10000, hrp.Position.Z)
                            chatLog("Hit " .. i .. "/" .. count)
                            
                            task.wait(1.5)
                        else
                            break
                        end
                    end
                    
                    hum.PlatformStand = false
                    forceReset(hum, char)
                end
                annoying = false
            end)
        end

    elseif cmd == ".smite" and args[2] then
        local smiteTarget = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                smiteTarget = p
                break
            end
        end
        
        if smiteTarget then
            task.spawn(function()
                smiting = true
                local char = getCharacter(player)
                local hum = char:WaitForChild("Humanoid")
                local hrp = getHRP(char)
                local tChar = smiteTarget.Character
                local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
                
                if hrp and tHRP and hum then
                    local originalPos = hrp.CFrame
                    hrp.CanCollide = false
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                    
                    local flingLoop = RunService.Heartbeat:Connect(function()
                        hrp.Velocity = Vector3.new(0, 999999, 0) + (hrp.Velocity * 999999)
                    end)

                    local endTime = tick() + 4
                    while tick() < endTime do
                        if tHRP and tHRP.Parent then
                            hrp.CFrame = tHRP.CFrame
                        else
                            break 
                        end
                        RunService.Heartbeat:Wait()
                    end

                    flingLoop:Disconnect()
                    stopVelocity(hrp)
                    hrp.CFrame = originalPos
                    smiting = false
                end
            end)
        end
    end
end

local function connect(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end

for _, p in pairs(Players:GetPlayers()) do connect(p) end
Players.PlayerAdded:Connect(connect)

chatLog("Cipher Ready. Anchored Physics Engaged.")
