if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- INITIAL STATE
local targetName = nil 
local running = false
local botOwnerName = "Rizalakasa" -- Initial authority

-- FEEDBACK SYSTEM
local function chatLog(text)
    game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
        Text = "[Cipher Protocol]: " .. text;
        Color = Color3.fromRGB(255, 120, 0);
        Font = Enum.Font.SourceSansBold;
    })
end

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    if myHRP then myHRP.CFrame = CFrame.new(-1210, 328, 4) end
                    task.wait(0.4)

                    for i = 1, 5 do
                        if not running or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    if running and humanoid and humanoid.Parent then
                        humanoid.Health = 0
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local speakerName = speaker.Name:lower()
    local speakerDisplayName = speaker.DisplayName:lower()
    local currentOwner = botOwnerName:lower()

    -- Only the current owner can issue commands
    if speakerName ~= currentOwner and speakerDisplayName ~= currentOwner then 
        return 
    end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    -- .START
    if cmd == ".start" then
        if targetName then
            running = true
            chatLog("Bot Engaged. Targeting: " .. targetName)
        else
            chatLog("Error: No target set. Use .target [name]")
        end

    -- .STOP
    elseif cmd == ".stop" then
        running = false
        chatLog("Bot Disengaged.")

    -- .TARGET [PlayerName]
    elseif cmd == ".target" and args[2] then
        local search = args[2]
        local found = false
        for _, p in pairs(Players:GetPlayers()) do
            if string.find(p.Name:lower(), search) or string.find(p.DisplayName:lower(), search) then
                targetName = p.Name
                chatLog("New Target: " .. targetName)
                found = true
                break
            end
        end
        if not found then chatLog("Target player not found.") end

    -- .OWNER [PlayerName]
    elseif cmd == ".owner" and args[2] then
        local search = args[2]
        local found = false
        for _, p in pairs(Players:GetPlayers()) do
            if string.find(p.Name:lower(), search) or string.find(p.DisplayName:lower(), search) then
                botOwnerName = p.Name
                chatLog("AUTHORITY TRANSFERRED TO: " .. botOwnerName)
                found = true
                -- Note: The original owner loses power immediately
                break
            end
        end
        if not found then chatLog("Owner player not found.") end
    end
end

-- HOOK CHAT
local function connectChat(p)
    p.Chatted:Connect(function(msg)
        processChat(msg, p)
    end)
end

for _, p in pairs(Players:GetPlayers()) do connectChat(p) end
Players.PlayerAdded:Connect(connectChat)

chatLog("Cipher Protocol Initialized. Current Owner: " .. botOwnerName)
