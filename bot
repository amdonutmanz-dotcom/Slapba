-- Cipher Protocol: Utility Expansion Patch (Collision Force Version)
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true
}
local smiting = false

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
end

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

local function forceReset(hum, char)
    if not hum or not char then return end
    pcall(function()
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
        hum:ChangeState(Enum.HumanoidStateType.Dead)
    end)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        -- Teleport slightly behind player
        myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName and not smiting then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    local portalPart = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Teleport1")

                    if myHRP and portalPart then 
                        local preTeleportPos = myHRP.Position
                        
                        -- Phase 1: Go to Portal and Jiggle to force .Touched
                        myHRP.CFrame = portalPart.CFrame
                        firetouchinterest(myHRP, portalPart, 0) -- Attempt to fire touch if executor supports it
                        task.wait(0.05)
                        myHRP.CFrame = portalPart.CFrame * CFrame.new(0, 0.1, 0) -- Nudge
                        firetouchinterest(myHRP, portalPart, 1)
                        
                        -- Phase 2: Validation Loop (Wait for the map change)
                        local startTick = tick()
                        repeat 
                            RunService.Heartbeat:Wait()
                        until (myHRP.Position - preTeleportPos).Magnitude > 15 or tick() - startTick > 2 or not running
                    end

                    if smiting or not running then return end

                    -- Phase 3: Strike Target
                    task.wait(0.1) -- Small buffer to ensure world load
                    for i = 1, 5 do
                        if not running or smiting or teleportToTarget() then break end
                        task.wait(0.1)
                    end

                    -- Phase 4: Wait for Credit
                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and not smiting and slappedVal.Value ~= targetName and timer < 8 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    -- Phase 5: Reset
                    if running and not smiting and humanoid and humanoid.Parent then
                        forceReset(humanoid, char)
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC (Unchanged)
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    local sDisplay = speaker.DisplayName:lower()
    if not owners[sName] and not owners[sDisplay] then return end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        running = true chatLog("Loop Resumed.")
    elseif cmd == ".stop" then
        running = false chatLog("Loop Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target Locked: " .. targetName)
                break
            end
        end
    elseif cmd == ".reset" then
        forceReset(player.Character:FindFirstChildOfClass("Humanoid"), player.Character)
    elseif cmd == ".rj" then
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".smite" and args[2] then
        -- Smite Logic (Unchanged)
    end
end

local function connect(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end

for _, p in pairs(Players:GetPlayers()) do connect(p) end
Players.PlayerAdded:Connect(connect)

chatLog("Cipher Active. Collision Force Protocol Engaged.")
