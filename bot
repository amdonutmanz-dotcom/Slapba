-- PRECISION FINDER
local function findTarget(name)
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower() == name or p.DisplayName:lower() == name then return p end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then return p end
    end
    return nil
end

-- AGGRESSIVE RESET
local function forceReset()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    pcall(function()
        if hum then hum.Health = 0 end
        char:BreakJoints()
        if char:FindFirstChild("Head") and char.Head:FindFirstChild("Neck") then
            char.Head.Neck:Destroy()
        end
    end)
end

-- COMBAT: 100K PREDICTIVE SMITE
local function executeSmite(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local tHum = targetP.Character:FindFirstChildOfClass("Humanoid")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP and tHum then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(100000, 100000, 100000)
            myHRP.RotVelocity = Vector3.new(0, 100000, 0)
        end)
        
        local strikeEnd = tick() + 5
        local side = 1
        
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent and tHum.Health > 0 do
            local prediction = tHRP.Position + (tHRP.Velocity * 0.12)
            side = side * -1
            local targetPos = prediction + (tHRP.CFrame.LookVector * (side * 6))
            myChar:PivotTo(CFrame.new(targetPos, prediction))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myHRP.RotVelocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

