-- Cipher Protocol: Linear High-Stability Farm
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwner = "rizalakasa"
local targetName = nil 
local running = false
local owners = { [primaryOwner:lower()] = true }
local smiting = false
local sessionSlaps = 0

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(100, 1, 100)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Parent = Workspace
end
createStealthPlate()

-- REJOIN ON KICK
game:GetService("GuiService").ErrorMessageChanged:Connect(function()
    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
end)

local function chatLog(text) print("[Cipher]: " .. text) end

local function forceReset()
    local char = player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.Anchored = false end
        char:BreakJoints()
    end
end

-- THE LINEAR FARM SEQUENCE
task.spawn(function()
    while true do
        task.wait(0.1)
        
        -- Only proceed if running, not smiting, and we have a target
        if running and not smiting and targetName then
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            -- Ensure we are alive and standing
            if hum and hum.Health > 0 and hrp then
                
                -- 1. PORTAL: Get into the game
                local portal = Workspace.Lobby:FindFirstChild("Teleport2")
                if portal then
                    char:PivotTo(portal.CFrame)
                    
                    -- Wait until the game actually gives you a glove/teleports you to arena
                    local startArenaWait = tick()
                    repeat task.wait() until (hrp.Position.Y < 200) or (tick() - startArenaWait > 2)
                    task.wait(0.3) -- Safety buffer for server sync
                end
                
                -- 2. TARGET: Find them
                local t = Players:FindFirstChild(targetName)
                local tHRP = t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                
                if tHRP and hrp.Parent then
                    -- Move to target and LOCK
                    hrp.Velocity = Vector3.zero
                    char:PivotTo(tHRP.CFrame * CFrame.new(0, 1.5, -3))
                    hrp.Anchored = true
                    
                    -- 3. VALUE CHECK: Wait for slap to register
                    local timeout = tick() + 2
                    local slapped = false
                    repeat 
                        local rag = Workspace:FindFirstChild("bp1frms") and Workspace.bp1frms:FindFirstChild("Ragdolled")
                        if rag and rag.Value == true then
                            slapped = true
                            sessionSlaps = sessionSlaps + 1
                        end
                        RunService.Heartbeat:Wait()
                    until slapped or tick() > timeout or not running
                    
                    -- 4. RESET: Clean the slate
                    hrp.Anchored = false
                    forceReset()
                    
                    -- 5. RESPAWN CHECK: Don't start next loop until old char is gone
                    local respawnWait = tick()
                    repeat task.wait() until (not player.Character or player.Character ~= char) or (tick() - respawnWait > 4)
                    task.wait(0.5) -- Final delay before starting over
                end
            end
        end
    end
end)

-- SMITE ENGINE (Keep this separate so it doesn't break the farm logic)
local function executeSmite(targetP)
    if not targetP or not targetP.Character or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(50000, 50000, 50000)
        end)
        
        local strikeEnd = tick() + 5
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 2))
            RunService.Heartbeat:Wait()
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -2))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

-- CHAT COMMANDS
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] then return end
    
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then running = true chatLog("Farm Active.")
    elseif cmd == ".stop" then running = false chatLog("Farm Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        owners[args[2]:lower()] = true
    elseif cmd == ".removeowner" and args[2] then
        if args[2]:lower() ~= primaryOwner:lower() then owners[args[2]:lower()] = nil end
    elseif cmd == ".smite" and args[2] then
        local p = Players:FindFirstChild(targetName) -- Uses farm target if found
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".reset" then forceReset()
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

-- STEALTH IDLE
RunService.Heartbeat:Connect(function()
    if not running and not smiting then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - stealthPos).Magnitude > 200 then
            hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
        end
    end
end)

chatLog("Linear Farm Suite Loaded. Use .target [name] then .farm")
