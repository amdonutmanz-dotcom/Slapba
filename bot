-- Cipher Protocol: Unified Farm & Management Suite
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = { ["rizalakasa"] = true }
local smiting = false

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
end

-- UTILITY FUNCTIONS
local function forceReset(hum, char)
    if not hum or not char then return end
    pcall(function()
        -- Breaking the neck joint is the most effective way to force a respawn
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
    end)
end

local function getTargetHRP()
    if not targetName then return nil end
    local target = Players:FindFirstChild(targetName)
    if target and target.Character then
        return target.Character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

-- MAIN FARM LOOP
task.spawn(function()
    while true do
        if running and targetName and not smiting then
            pcall(function()
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local hrp = char and char:FindFirstChild("HumanoidRootPart")

                if hum and hum.Health > 0 and hrp then
                    -- 1. Teleport to Lobby Wait Spot
                    hrp.CFrame = CFrame.new(-1210, 328, -8)
                    task.wait(0.3)

                    -- 2. Teleport In Front of Target
                    local tHRP = getTargetHRP()
                    if tHRP then
                        char:PivotTo(tHRP.CFrame * CFrame.new(0, 0, -3))
                        
                        -- 3. Wait for Ragdoll Value
                        local ragdolled = workspace:FindFirstChild("bp1frms") and workspace.bp1frms:FindFirstChild("Ragdolled")
                        if ragdolled then
                            local startWait = tick()
                            -- Wait for ragdoll to be true (with a 5s timeout)
                            while running and not ragdolled.Value and tick() - startWait < 5 do
                                task.wait(0.1)
                            end
                            
                            -- 4. Effective Reset
                            if ragdolled.Value then
                                forceReset(hum, char)
                                player.CharacterAdded:Wait()
                                task.wait(0.5)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.1)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    local sDisplay = speaker.DisplayName:lower()

    if not owners[sName] and not owners[sDisplay] then return end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then
        running = true 
        chatLog("Farm Loop Started.")
    elseif cmd == ".stop" then
        running = false 
        chatLog("Farm Loop Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target Locked: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Owner Added: " .. p.Name)
                break
            end
        end
    elseif cmd == ".removeowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                if p.Name:lower() ~= "rizalakasa" then
                    owners[p.Name:lower()] = nil
                    chatLog("Owner Removed: " .. p.Name)
                else
                    chatLog("Cannot remove primary owner.")
                end
                break
            end
        end
    elseif cmd == ".reset" then
        chatLog("Resetting...")
        forceReset(player.Character:FindFirstChildOfClass("Humanoid"), player.Character)
    elseif cmd == ".rj" or cmd == ".rejoin" then
        chatLog("Rejoining...")
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".smite" and args[2] then
        local smiteTarget = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                smiteTarget = p
                break
            end
        end
        
        if smiteTarget then
            task.spawn(function()
                smiting = true
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local tHRP = smiteTarget.Character and smiteTarget.Character:FindFirstChild("HumanoidRootPart")
                
                if hrp and tHRP and hum then
                    local originalPos = hrp.CFrame
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                    
                    local flingLoop = RunService.Heartbeat:Connect(function()
                        hrp.Velocity = Vector3.new(0, 9000, 0)
                        RunService.RenderStepped:Wait()
                        hrp.Velocity = Vector3.new(9000, 9000, 9000)
                    end)

                    local endTime = tick() + 2
                    while tick() < endTime and tHRP.Parent do
                        char:PivotTo(tHRP.CFrame * CFrame.new(math.random(-1,1), 0, math.random(-1,1)))
                        RunService.Heartbeat:Wait()
                    end

                    flingLoop:Disconnect()
                    hrp.Velocity = Vector3.zero
                    char:PivotTo(originalPos)
                    smiting = false
                    chatLog("Smite Done.")
                else
                    smiting = false
                end
            end)
        end
    end
end

-- HOOKS
for _, p in pairs(Players:GetPlayers()) do
    p.Chatted:Connect(function(m) processChat(m, p) end)
end
Players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end)

chatLog("Cipher Active. Target-Response Farm Loaded.")
