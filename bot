print("CIPHER: Patience Protocol Loading...")

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true,
    [player.Name:lower()] = true
}

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[Cipher Protocol]: " .. text;
            Color = Color3.fromRGB(255, 120, 0);
            Font = Enum.Font.SourceSansBold;
        })
    end)
end

-- HELPER FUNCTIONS
local function getHRP(plr)
    local char = plr.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myHRP = getHRP(player)
    
    if targetHRP and myHRP then
        myHRP.Velocity = Vector3.zero
        -- Teleport slightly closer (2 studs) to ensure contact
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 2)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            pcall(function()
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local hrp = getHRP(player)
                
                if hum and hrp and hum.Health > 0 then
                    -- STEP 1: TRAVEL TO PREP (Portal)
                    hrp.CFrame = CFrame.new(-1210, 328, 4)
                    task.wait(0.6) -- Added more time for portal transition

                    -- STEP 2: TRAVEL TO TARGET
                    local reached = false
                    for i = 1, 10 do -- Increased retries
                        if not running then break end
                        if teleportToTarget() then 
                            reached = true 
                            break 
                        end
                        task.wait(0.2)
                    end

                    -- STEP 3: THE PATIENT WATCHER
                    if reached then
                        local bp1 = workspace:FindFirstChild("bp1frms")
                        local slapVal = bp1 and bp1:FindFirstChild("LastSlappedBy")
                        
                        -- WAIT UNTIL SLAP REGISTERS (Max 6 seconds)
                        local timer = 0
                        while running and timer < 6 do
                            if slapVal and slapVal.Value == targetName then
                                chatLog("Slap Confirmed on " .. targetName)
                                break 
                            end
                            -- Keep forcing position while waiting for the slap
                            teleportToTarget() 
                            timer = timer + task.wait(0.1)
                        end
                        task.wait(0.3) -- Final buffer to ensure server catch-up
                    end

                    -- STEP 4: RESET
                    if running and hum.Health > 0 then
                        hum.Health = 0
                        task.wait(0.2)
                        player.CharacterAdded:Wait()
                        task.wait(0.7) -- Post-spawn wait
                    end
                end
            end)
        end
        task.wait(0.1)
    end
end)

-- COMMAND LOGIC
local function onChat(msg, speaker)
    local name = speaker.Name:lower()
    local display = speaker.DisplayName:lower()
    
    if not owners[name] and not owners[display] then return end

    local args = msg:lower():split(" ")
    local cmd = args[1]

    if cmd == ".start" then
        if targetName then running = true chatLog("Bot Started.") else chatLog("Error: No target.") end
    elseif cmd == ".stop" then
        running = false
        chatLog("Bot Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Added Owner: " .. p.Name)
                break
            end
        end
    elseif cmd == ".removeowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                if p.Name:lower() ~= "rizalakasa" then -- Safety for main owner
                    owners[p.Name:lower()] = nil
                    chatLog("Removed Owner: " .. p.Name)
                end
                break
            end
        end
    elseif cmd == ".clearowners" then
        owners = {["rizalakasa"] = true, [player.Name:lower()] = true}
        chatLog("Ownership list reset to defaults.")
    end
end

-- CONNECTIONS
for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) onChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) onChat(m, p) end) end)

chatLog("System Online. Target Required.")
