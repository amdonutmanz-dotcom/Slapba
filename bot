print("CIPHER: Reliable Reset Protocol Loading...")

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true,
    [player.Name:lower()] = true
}

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[Cipher Protocol]: " .. text;
            Color = Color3.fromRGB(255, 120, 0);
            Font = Enum.Font.SourceSansBold;
        })
    end)
end

-- HELPER FUNCTIONS
local function getHRP(plr)
    local char = plr.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myHRP = getHRP(player)
    
    if targetHRP and myHRP then
        myHRP.Velocity = Vector3.zero
        -- Offset slightly so we don't just glitch inside them
        myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, -2.5) * CFrame.Angles(0, math.pi, 0)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            pcall(function()
                local char = player.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local hrp = getHRP(player)
                
                local targetObj = Players:FindFirstChild(targetName)
                local targetHum = targetObj and targetObj.Character and targetObj.Character:FindFirstChildOfClass("Humanoid")
                
                if hum and hrp and hum.Health > 0 then
                    -- STEP 1: PORTAL
                    hrp.CFrame = CFrame.new(-1210, 328, 4)
                    task.wait(0.5)

                    -- STEP 2: TARGET TELEPORT
                    local reached = false
                    for i = 1, 8 do
                        if not running then break end
                        if teleportToTarget() then reached = true break end
                        task.wait(0.2)
                    end

                    -- STEP 3: THE SMART WATCHER
                    if reached then
                        local bp1 = workspace:FindFirstChild("bp1frms")
                        local slapVal = bp1 and bp1:FindFirstChild("LastSlappedBy")
                        local startHealth = targetHum and targetHum.Health or 100
                        
                        local timer = 0
                        while running and timer < 5 do
                            -- SUCCESS CONDITION 1: Value Match
                            if slapVal and tostring(slapVal.Value):lower() == targetName:lower() then
                                break
                            end
                            
                            -- SUCCESS CONDITION 2: Target Health dropped (slapped)
                            if targetHum and targetHum.Health < startHealth then
                                break
                            end
                            
                            -- Keep glued to target while waiting
                            teleportToTarget()
                            timer = timer + task.wait(0.1)
                        end
                    end

                    -- STEP 4: RESET (Forceful)
                    if running then
                        task.wait(0.1)
                        hum.Health = 0
                        -- Wait for character removal
                        local oldChar = player.Character
                        repeat task.wait() until player.Character ~= oldChar
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.1)
    end
end)

-- COMMAND LOGIC
local function onChat(msg, speaker)
    local name = speaker.Name:lower()
    local display = speaker.DisplayName:lower()
    
    if not owners[name] and not owners[display] then return end

    local args = msg:lower():split(" ")
    local cmd = args[1]

    if cmd == ".start" then
        if targetName then running = true chatLog("Bot Active.") else chatLog("Error: No target.") end
    elseif cmd == ".stop" then
        running = false
        chatLog("Bot Stopped.")
    elseif cmd == ".target" and args[2] then
        local found = false
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target: " .. targetName)
                found = true
                break
            end
        end
        if not found then chatLog("Player not found.") end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Added: " .. p.Name)
                break
            end
        end
    elseif cmd == ".removeowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                if p.Name:lower() ~= "rizalakasa" then
                    owners[p.Name:lower()] = nil
                    chatLog("Removed: " .. p.Name)
                end
                break
            end
        end
    elseif cmd == ".clearowners" then
        owners = {["rizalakasa"] = true, [player.Name:lower()] = true}
        chatLog("Owners reset.")
    end
end

-- CONNECTIONS
for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) onChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) onChat(m, p) end) end)

chatLog("System Online.")
