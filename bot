-- Cipher Protocol: High-Speed Bulletproof Farm
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwner = "rizalakasa"
local targetName = nil 
local running = false
local owners = { [primaryOwner:lower()] = true }
local smiting = false
local sessionSlaps = 0

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(100, 1, 100)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Parent = Workspace
end
createStealthPlate()

-- REJOIN ON KICK
game:GetService("GuiService").ErrorMessageChanged:Connect(function()
    task.wait(0.5)
    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
end)

local function chatLog(text) print("[Cipher]: " .. text) end

local function forceReset()
    local char = player.Character
    if char then
        pcall(function()
            if char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.Anchored = false
            end
            char:BreakJoints() -- Force instant kill
        end)
    end
end

-- HIGH-SPEED FARM ENGINE
task.spawn(function()
    while true do
        RunService.Heartbeat:Wait() -- Run as fast as physics allows
        
        if running and not smiting and targetName then
            local char = player.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if hum and hum.Health > 0 and hrp then
                
                -- 1. PORTAL JUMP
                local portal = Workspace.Lobby:FindFirstChild("Teleport2")
                if portal then
                    char:PivotTo(portal.CFrame)
                    
                    -- Fast arena detection
                    local startArenaWait = tick()
                    repeat task.wait() until (hrp.Position.Y < 200) or (tick() - startArenaWait > 1.5)
                end
                
                -- 2. STRIKE
                local t = Players:FindFirstChild(targetName)
                local tHRP = t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                
                if tHRP and hrp.Parent then
                    hrp.Velocity = Vector3.zero
                    char:PivotTo(tHRP.CFrame * CFrame.new(0, 1.5, -3.5))
                    hrp.Anchored = true -- Lock for hit
                    
                    -- 3. SMARTER HIT DETECTION (Detects physics change or value)
                    local timeout = tick() + 0.8 -- Faster timeout
                    local hit = false
                    repeat 
                        local ragFolder = Workspace:FindFirstChild("bp1frms")
                        local ragValue = ragFolder and ragFolder:FindFirstChild("Ragdolled")
                        
                        -- If target flies away or value changes, hit is confirmed
                        if (ragValue and ragValue.Value == true) or (tHRP.Velocity.Magnitude > 20) then
                            hit = true
                            sessionSlaps = sessionSlaps + 1
                        end
                        RunService.Heartbeat:Wait()
                    until hit or tick() > timeout
                    
                    -- 4. INSTANT RESET
                    hrp.Anchored = false
                    forceReset()
                    
                    -- 5. FAST RESPAWN SYNC
                    repeat RunService.Heartbeat:Wait() until player.Character ~= char
                    task.wait(0.1) -- Minimal breathing room to prevent double-teleport
                end
            end
        end
    end
end)

-- SMITE ENGINE
local function executeSmite(targetP)
    if not targetP or not targetP.Character or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(50000, 50000, 50000)
        end)
        
        local strikeEnd = tick() + 5
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 2))
            RunService.Heartbeat:Wait()
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -2))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

-- COMMANDS
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] then return end
    
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then running = true chatLog("Farm: ON")
    elseif cmd == ".stop" then running = false chatLog("Farm: OFF")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Locked: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        owners[args[2]:lower()] = true
    elseif cmd == ".removeowner" and args[2] then
        if args[2]:lower() ~= primaryOwner:lower() then owners[args[2]:lower()] = nil end
    elseif cmd == ".smite" then
        local p = Players:FindFirstChild(targetName or "")
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then forceReset()
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

-- STEALTH
RunService.Heartbeat:Connect(function()
    if not running and not smiting then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - stealthPos).Magnitude > 200 then
            hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
        end
    end
end)

chatLog("Speed-Farm Loaded. Faster transitions active.")
