-- Cipher Protocol: Unified Farm & Management (Auto-White Integration)
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")

-- INITIAL STATE
local primaryOwner = "rizalakasa"
local targetName = nil 
local running = false
local owners = { [primaryOwner] = true }
local whitelist = { [primaryOwner] = true } 
local smiting = false
local loopsmiting = nil
local hiding = true
local sessionSlaps = 0
local startTime = tick()
local flingPower = 35000 

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(50, 1, 50)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Transparency = 1
    plate.Parent = workspace
end
createStealthPlate()

-- ANTI-AFK
for i,v in pairs(getconnections(player.Idled)) do v:Disable() end

local function chatLog(text) print("[Cipher]: " .. text) end

-- AUTO-WHITE LOGIC
local function checkAndWhite(p)
    if p == player then return end
    if p:IsFriendsWith(player.UserId) or p.Name:lower() == primaryOwner:lower() then
        whitelist[p.Name:lower()] = true
        chatLog("Auto-Whitelisted: " .. p.Name)
    end
end

-- INITIAL SCAN
for _, p in pairs(Players:GetPlayers()) do checkAndWhite(p) end
Players.PlayerAdded:Connect(checkAndWhite)

local function isImmune(name)
    return name:lower() == primaryOwner:lower()
end

local function forceReset(hum, char)
    if not hum or not char then return end
    pcall(function()
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
    end)
end

-- SMITE EXECUTION
local function executeSmite(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or isImmune(targetP.Name) then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local originalPos = myHRP.CFrame
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(flingPower, flingPower, flingPower)
        end)
        
        local strikeTime = tick() + 0.4
        while tick() < strikeTime and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame)
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(originalPos)
        smiting = false
    end
end

-- MAIN ENGINE
task.spawn(function()
    while true do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if loopsmiting and not smiting then
            local target = Players:FindFirstChild(loopsmiting)
            if target then executeSmite(target) else loopsmiting = nil end
        elseif running and targetName and not smiting then
            pcall(function()
                if hum and hum.Health > 0 and hrp then
                    hrp.CFrame = CFrame.new(-1210, 328, -8)
                    task.wait(0.3)
                    local target = Players:FindFirstChild(targetName)
                    local tHRP = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
                    
                    if tHRP then
                        char:PivotTo(tHRP.CFrame * CFrame.new(0, 0, -3))
                        local rag = workspace:FindFirstChild("bp1frms") and workspace.bp1frms:FindFirstChild("Ragdolled")
                        local startW = tick()
                        repeat RunService.Heartbeat:Wait()
                        until (rag and rag.Value) or (tHRP and (hrp.Position - tHRP.Position).Magnitude > 12) or tick()-startW > 3 or not running
                        
                        sessionSlaps = sessionSlaps + 1
                        forceReset(hum, char)
                        local rTimer = tick()
                        repeat task.wait() until player.Character or tick()-rTimer > 3
                        task.wait(0.3)
                    end
                end
            end)
        else
            if hiding and hrp and (hrp.Position - stealthPos).Magnitude > 100 and not smiting then
                hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
            end
        end
        task.wait(0.01)
    end
end)

-- COMMANDS
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] and not owners[speaker.DisplayName:lower()] then return end
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then running = true chatLog("Farm Active.")
    elseif cmd == ".stop" then running = false chatLog("Farm Stopped.")
    elseif cmd == ".velocity" and args[2] then
        flingPower = tonumber(args[2]) or 35000
        chatLog("Smite Power: " .. flingPower)
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) then targetName = p.Name chatLog("Target: "..targetName) break end
        end
    elseif cmd == ".smite" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) then executeSmite(p) break end
        end
    elseif cmd == ".loopsmite" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) then
                if isImmune(p.Name) then return end
                loopsmiting = p.Name chatLog("Looping: "..p.Name) break 
            end
        end
    elseif cmd == ".unloopsmite" then loopsmiting = nil chatLog("Loop Off.")
    elseif cmd == ".white" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) then whitelist[p.Name:lower()] = true chatLog("Whitelisted: "..p.Name) break end
        end
    elseif cmd == ".unwhite" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) then
                if isImmune(p.Name) then return end
                whitelist[p.Name:lower()] = nil chatLog("Un-whitelisted: "..p.Name) break 
            end
        end
    elseif cmd == ".hide" then hiding = not hiding chatLog("Hide: "..tostring(hiding))
    elseif cmd == ".stats" then chatLog("Cycles: "..sessionSlaps.." | Uptime: "..math.floor(tick()-startTime).."s")
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then forceReset(player.Character:FindFirstChildOfClass("Humanoid"), player.Character)
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) then owners[p.Name:lower()] = true chatLog("Added Owner: "..p.Name) break end
        end
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

chatLog("Cipher Ultimate: Auto-White engaged (scanning friends).")
