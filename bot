-- NO WAITS AT THE TOP - RUN IMMEDIATELY
print("CIPHER DEBUG: SCRIPT EXECUTING") 

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true,
    [player.Name:lower()] = true -- Adding you by default just to be safe
}

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[Cipher Protocol]: " .. text;
            Color = Color3.fromRGB(255, 120, 0);
            Font = Enum.Font.SourceSansBold;
        })
    end)
end

-- HELPER FUNCTIONS
local function getHRP(plr)
    local char = plr.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myHRP = getHRP(player)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = getHRP(player)
            
            if hum and hrp and hum.Health > 0 then
                -- STEP 1
                hrp.CFrame = CFrame.new(-1210, 328, 4)
                task.wait(0.4)

                -- STEP 2
                for i = 1, 5 do
                    if not running or teleportToTarget() then break end
                    task.wait(0.2)
                end

                -- STEP 3
                local bp1 = workspace:FindFirstChild("bp1frms")
                local slapVal = bp1 and bp1:FindFirstChild("LastSlappedBy")
                if slapVal then
                    local t = 0
                    while running and slapVal.Value ~= targetName and t < 5 do
                        t = t + task.wait(0.1)
                    end
                end

                -- STEP 4
                if running and hum.Health > 0 then
                    hum.Health = 0
                    player.CharacterAdded:Wait()
                    task.wait(0.5)
                end
            end
        end
        task.wait(0.1)
    end
end)

-- COMMAND LOGIC
local function onChat(msg, speaker)
    local name = speaker.Name:lower()
    local display = speaker.DisplayName:lower()
    
    if not owners[name] and not owners[display] then return end

    local args = msg:lower():split(" ")
    local cmd = args[1]

    if cmd == ".start" then
        running = true
        chatLog("Bot Started.")
    elseif cmd == ".stop" then
        running = false
        chatLog("Bot Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target set to: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Added Owner: " .. p.Name)
                break
            end
        end
    end
end

-- CONNECTIONS
for _, p in pairs(Players:GetPlayers()) do
    p.Chatted:Connect(function(m) onChat(m, p) end)
end

Players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(m) onChat(m, p) end)
end)

chatLog("System Ready. Target required.")
