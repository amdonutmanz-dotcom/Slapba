-- Cipher Protocol: Full Unified Farm, Smite, & Annoyance Suite
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwner = "rizalakasa"
local targetName = nil 
local running = false
local owners = { [primaryOwner] = true }
local whitelist = { [primaryOwner] = true } 
local smiting = false
local loopsmiting = nil
local annoying = false
local loopAnnoying = nil
local hiding = true
local sessionSlaps = 0
local startTime = tick()

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(50, 1, 50)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Transparency = 1
    plate.Parent = Workspace
end
createStealthPlate()

-- ANTI-AFK
for i,v in pairs(getconnections(player.Idled)) do v:Disable() end

local function chatLog(text) print("[Cipher]: " .. text) end

-- PRECISION FINDER
local function findTarget(name)
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower() == name or p.DisplayName:lower() == name then return p end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then return p end
    end
    return nil
end

-- AUTO-WHITE (Friends)
local function checkAndWhite(p)
    if p == player then return end
    if p:IsFriendsWith(player.UserId) or p.Name:lower() == primaryOwner:lower() then
        whitelist[p.Name:lower()] = true
    end
end
for _, p in pairs(Players:GetPlayers()) do checkAndWhite(p) end
Players.PlayerAdded:Connect(checkAndWhite)

local function forceReset()
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    pcall(function()
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
    end)
end

-- COMBAT: SMITE ENGINE (5s Back-and-Forth)
local function executeSmite(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(50000, 50000, 50000)
        end)
        
        local strikeEnd = tick() + 5
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 3))
            RunService.Heartbeat:Wait()
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -3))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

-- COMBAT: ANNOY ENGINE (Lobby -> Tool -> Strike)
local function executeAnnoy(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or annoying then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if tHRP and hrp then
        annoying = true
        hrp.Velocity = Vector3.zero
        char:PivotTo(Workspace.Lobby.Teleport2.CFrame)
        
        local tool = nil
        local startTimeWait = tick()
        repeat 
            tool = char:FindFirstChildOfClass("Tool") or player.Backpack:FindFirstChildOfClass("Tool")
            task.wait()
        until tool or tick() - startTimeWait > 2
        
        if tool then
            tool.Parent = char
            local handle = tool:FindFirstChild("Handle")
            if handle then
                local oldSize = handle.Size
                handle.Size = oldSize * 10
                hrp.Velocity = Vector3.zero
                char:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 3))
                task.wait(0.1)
                tool:Activate()
                task.wait(0.1)
                handle.Size = oldSize
            end
        end

        char:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        task.wait(1.5)
        annoying = false
    end
end

-- MAIN BACKGROUND ENGINE
task.spawn(function()
    while true do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if loopAnnoying and not annoying then
            local t = Players:FindFirstChild(loopAnnoying)
            if t then executeAnnoy(t) else loopAnnoying = nil end
        elseif loopsmiting and not smiting then
            local t = Players:FindFirstChild(loopsmiting)
            if t then executeSmite(t) else loopsmiting = nil end
        elseif running and targetName and not smiting and not annoying then
            pcall(function()
                if hum and hum.Health > 0 and hrp then
                    hrp.CFrame = CFrame.new(-1210, 328, -8) -- Lobby
                    task.wait(0.3)
                    local t = Players:FindFirstChild(targetName)
                    local tHRP = t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                    if tHRP then
                        char:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -3))
                        local rag = Workspace:FindFirstChild("bp1frms") and Workspace.bp1frms:FindFirstChild("Ragdolled")
                        local startW = tick()
                        repeat RunService.Heartbeat:Wait()
                        until (rag and rag.Value) or (tHRP and (hrp.Position-tHRP.Position).Magnitude > 12) or tick()-startW > 3 or not running
                        sessionSlaps = sessionSlaps + 1
                        forceReset()
                        task.wait(0.5)
                    end
                end
            end)
        else
            if hiding and hrp and (hrp.Position - stealthPos).Magnitude > 100 and not smiting and not annoying then
                hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
            end
        end
        task.wait(0.01)
    end
end)

-- COMMAND HANDLER
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] and not owners[speaker.DisplayName:lower()] then return end
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then running = true chatLog("Farm On.")
    elseif cmd == ".stop" then running = false chatLog("Farm Off.")
    elseif cmd == ".target" and args[2] then
        local p = findTarget(args[2])
        if p then targetName = p.Name chatLog("Farm Target: "..p.Name) end
    elseif cmd == ".smite" and args[2] then
        local p = findTarget(args[2])
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".loopsmite" and args[2] then
        local p = findTarget(args[2])
        if p then loopsmiting = p.Name chatLog("Loop Smite: "..p.Name) end
    elseif cmd == ".unloopsmite" then loopsmiting = nil chatLog("Loop Smite Stopped.")
    elseif cmd == ".annoy" and args[2] then
        local p = findTarget(args[2])
        local times = tonumber(args[3]) or 1
        if p then task.spawn(function() for i=1, times do executeAnnoy(p) end forceReset() end) end
    elseif cmd == ".loopannoy" and args[2] then
        local p = findTarget(args[2])
        if p then loopAnnoying = p.Name chatLog("Loop Annoy: "..p.Name) end
    elseif cmd == ".unloopannoy" then loopAnnoying = nil forceReset() chatLog("Loop Annoy Stopped.")
    elseif cmd == ".white" and args[2] then
        local p = findTarget(args[2])
        if p then whitelist[p.Name:lower()] = true chatLog("Whitelisted: "..p.Name) end
    elseif cmd == ".stats" then chatLog("Slaps: "..sessionSlaps.." | Uptime: "..math.floor(tick()-startTime).."s")
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then forceReset()
    elseif cmd == ".addowner" and args[2] then
        local p = findTarget(args[2])
        if p then owners[p.Name:lower()] = true chatLog("Added Owner: "..p.Name) end
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

chatLog("Cipher Ultimate: Complete Source Loaded.")
