-- Re-verifying the stable base with the upgraded Smite
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true
}

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

-- UPGRADED FLING (More aggressive)
local function setFling(state)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if state then
        -- High-power physics manipulation
        task.spawn(function()
            while _G.Smiting do
                hrp.Velocity = Vector3.new(9e9, 9e9, 9e9)
                hrp.RotVelocity = Vector3.new(9e9, 9e9, 9e9)
                RunService.Heartbeat:Wait()
            end
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
        end)
    end
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    if myHRP then myHRP.CFrame = CFrame.new(-1210, 328, 4) end
                    task.wait(0.4)

                    for i = 1, 5 do
                        if not running or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    if running and humanoid and humanoid.Parent then
                        humanoid.Health = 0
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local speakerName = speaker.Name:lower()
    local speakerDisplayName = speaker.DisplayName:lower()

    if not owners[speakerName] and not owners[speakerDisplayName] then 
        return 
    end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        if targetName then running = true print("Cipher: Started.") else print("Cipher: No target.") end
    elseif cmd == ".stop" then
        running = false print("Cipher: Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                print("Cipher: Target is now " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                print("Cipher: Added owner " .. p.Name)
                break
            end
        end
    
    -- RE-CODED SMITE
    elseif cmd == ".smite" and args[2] then
        local smiteTarget = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                smiteTarget = p
                break
            end
        end
        
        if smiteTarget and smiteTarget.Character then
            task.spawn(function()
                local myChar = player.Character
                local myHRP = getHRP(myChar)
                local tHRP = smiteTarget.Character:FindFirstChild("HumanoidRootPart")
                
                if myHRP and tHRP then
                    local originalPos = myHRP.CFrame
                    _G.Smiting = true
                    setFling(true)
                    
                    local startTime = tick()
                    while tick() - startTime < 4 do
                        if tHRP and tHRP.Parent then
                            -- We stay inside them, but keep moving slightly to trigger physics collision
                            myHRP.CFrame = tHRP.CFrame * CFrame.new(math.random(-1,1), 0, math.random(-1,1))
                        end
                        RunService.Stepped:Wait()
                    end
                    
                    _G.Smiting = false
                    task.wait(0.1)
                    myHRP.CFrame = originalPos
                    print("Cipher: Smite finished.")
                end
            end)
        end
    end
end

local function connectChat(p)
    p.Chatted:Connect(function(msg) processChat(msg, p) end)
end

for _, p in pairs(Players:GetPlayers()) do connectChat(p) end
Players.PlayerAdded:Connect(connectChat)

print("Cipher Protocol Active. Smite Upgraded.")
