-- Final Check: All brackets and ends accounted for.
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- INITIAL STATE
local targetName = nil 
local running = false
-- Changed to a table to support multiple owners
local owners = {
    ["rizalakasa"] = true
}

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    if myHRP then myHRP.CFrame = CFrame.new(-1210, 328, 4) end
                    task.wait(0.4)

                    for i = 1, 5 do
                        if not running or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    if running and humanoid and humanoid.Parent then
                        humanoid.Health = 0
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local speakerName = speaker.Name:lower()
    local speakerDisplayName = speaker.DisplayName:lower()

    -- Check if the person talking is an owner
    if not owners[speakerName] and not owners[speakerDisplayName] then 
        return 
    end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        if targetName then
            running = true
            print("Cipher: Started targeting " .. targetName)
        else
            print("Cipher: Set a target first.")
        end
    elseif cmd == ".stop" then
        running = false
        print("Cipher: Stopped.")
    elseif cmd == ".target" and args[2] then
        local search = args[2]
        for _, p in pairs(Players:GetPlayers()) do
            if string.find(p.Name:lower(), search) or string.find(p.DisplayName:lower(), search) then
                targetName = p.Name
                print("Cipher: Target is now " .. targetName)
                break
            end
        end
    -- NEW COMMAND: .addowner [name]
    elseif cmd == ".addowner" and args[2] then
        local search = args[2]
        for _, p in pairs(Players:GetPlayers()) do
            if string.find(p.Name:lower(), search) or string.find(p.DisplayName:lower(), search) then
                owners[p.Name:lower()] = true
                print("Cipher: Added " .. p.Name .. " as an owner.")
                break
            end
        end
    elseif cmd == ".owner" and args[2] then
        local search = args[2]
        for _, p in pairs(Players:GetPlayers()) do
            if string.find(p.Name:lower(), search) or string.find(p.DisplayName:lower(), search) then
                -- This still resets the list to just one person
                owners = {[p.Name:lower()] = true}
                print("Cipher: Owner is now " .. p.Name)
                break
            end
        end
    end
end

-- HOOK CHAT
local function connectChat(p)
    p.Chatted:Connect(function(msg)
        processChat(msg, p)
    end)
end

for _, p in pairs(Players:GetPlayers()) do
    connectChat(p)
end

Players.PlayerAdded:Connect(function(p)
    connectChat(p)
end)

print("Cipher Protocol Active. Initial Owner: Rizalakasa")
