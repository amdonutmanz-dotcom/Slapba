-- Cipher Protocol: Utility Expansion Patch (Failsafe + Watchdog Edition)
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = { ["rizalakasa"] = true }
local smiting = false
local lastActivity = tick() -- Watchdog timer

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
end

-- HELPER FUNCTIONS
local function forceReset(hum, char)
    if not hum or not char then return end
    pcall(function()
        local head = char:FindFirstChild("Head")
        if head and head:FindFirstChildOfClass("Motor6D") then
            head:FindFirstChildOfClass("Motor6D"):Destroy()
        end
        hum.Health = 0
    end)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    local myChar = player.Character
    if not target or not target.Character or not myChar then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    if targetHRP then
        myChar:PivotTo(targetHRP.CFrame * CFrame.new(0, 0, -3))
        return true
    end
    return false
end

-- WATCHDOG FAILSAFE (Restarts loop if stuck for 20s)
task.spawn(function()
    while true do
        if running and not smiting then
            if tick() - lastActivity > 20 then
                chatLog("Failsafe Triggered: Bot was stuck. Resetting...")
                local char = player.Character
                if char then forceReset(char:FindFirstChildOfClass("Humanoid"), char) end
                lastActivity = tick() -- Reset timer
            end
        end
        task.wait(2)
    end
end)

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName and not smiting then
            lastActivity = tick()
            pcall(function()
                local char = player.Character
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = char:FindFirstChild("HumanoidRootPart")
                    local portalPart = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Teleport1")

                    -- Phase 1: Portal Entry
                    if myHRP and portalPart then 
                        local preTeleportPos = myHRP.Position
                        local portalTimeout = tick()
                        
                        repeat 
                            char:PivotTo(portalPart.CFrame * CFrame.new(math.random(-1,1)/5, 0, math.random(-1,1)/5))
                            if firetouchinterest then 
                                firetouchinterest(myHRP, portalPart, 0)
                                task.wait()
                                firetouchinterest(myHRP, portalPart, 1)
                            end
                            task.wait(0.2)
                        until (myHRP.Position - preTeleportPos).Magnitude > 15 or tick() - portalTimeout > 3 or not running
                    end

                    if smiting or not running then return end
                    lastActivity = tick()

                    -- Phase 2: Strike
                    task.wait(0.2) 
                    local strikeSuccess = false
                    for i = 1, 10 do
                        if teleportToTarget() then strikeSuccess = true break end
                        task.wait(0.1)
                    end

                    -- Phase 3: Wait for slap credit (with timeout)
                    if strikeSuccess then
                        local bp1frms = workspace:FindFirstChild("bp1frms")
                        local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")
                        local creditTimer = tick()

                        if slappedVal then
                            while running and not smiting and slappedVal.Value ~= targetName and tick() - creditTimer < 5 do
                                task.wait(0.1)
                            end
                        end
                    end

                    -- Phase 4: Reset & Wait for Respawn
                    if running and not smiting then
                        forceReset(humanoid, char)
                        -- Robust respawn wait
                        local newChar = player.CharacterAdded:Wait()
                        newChar:WaitForChild("HumanoidRootPart", 10)
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] and not owners[speaker.DisplayName:lower()] then return end
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        running = true 
        lastActivity = tick()
        chatLog("Bot Started.")
    elseif cmd == ".stop" then
        running = false 
        chatLog("Bot Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target: " .. targetName)
                break
            end
        end
    elseif cmd == ".reset" then
        local char = player.Character
        forceReset(char:FindFirstChildOfClass("Humanoid"), char)
    elseif cmd == ".smite" and args[2] then
        local smiteTarget = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                smiteTarget = p
                break
            end
        end
        
        if smiteTarget then
            task.spawn(function()
                smiting = true
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                local tChar = smiteTarget.Character
                local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
                
                if hrp and tHRP and hum then
                    local originalPos = hrp.CFrame
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                    
                    local flingLoop = RunService.Heartbeat:Connect(function()
                        hrp.Velocity = Vector3.new(0, 5000, 0)
                        RunService.RenderStepped:Wait()
                        hrp.Velocity = Vector3.new(5000, 5000, 5000)
                    end)

                    local endTime = tick() + 3
                    while tick() < endTime and tHRP.Parent do
                        char:PivotTo(tHRP.CFrame * CFrame.new(math.random(-1,1), 0, math.random(-1,1)))
                        RunService.Heartbeat:Wait()
                    end

                    flingLoop:Disconnect()
                    hrp.Velocity = Vector3.zero
                    char:PivotTo(originalPos)
                    smiting = false
                    chatLog("Smite Finished.")
                else
                    smiting = false
                end
            end)
        end
    end
end

-- INITIALIZE
for _, p in pairs(Players:GetPlayers()) do
    p.Chatted:Connect(function(m) processChat(m, p) end)
end
Players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end)

chatLog("Cipher Loaded. Failsafe Watchdog Active.")
