-- Cipher Protocol: Reverted Farm Logic with Owner Suite
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwner = "rizalakasa"
local targetName = nil 
local running = false
local owners = { [primaryOwner:lower()] = true }
local whitelist = { [primaryOwner:lower()] = true } 
local smiting = false
local loopsmiting = nil
local hiding = true
local sessionSlaps = 0

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(100, 1, 100)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Parent = Workspace
end
createStealthPlate()

-- ANTI-AFK
for i,v in pairs(getconnections(player.Idled)) do v:Disable() end

local function chatLog(text) print("[Cipher]: " .. text) end

-- PRECISION FINDER
local function findTarget(name)
    if not name then return nil end
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower() == name or p.DisplayName:lower() == name then return p end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then return p end
    end
    return nil
end

local function forceReset()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    pcall(function()
        if char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.Anchored = false
        end
        if hum then hum.Health = 0 end
        char:BreakJoints()
    end)
end

-- COMBAT: SMITE ENGINE
local function executeSmite(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(50000, 50000, 50000)
        end)
        
        local strikeEnd = tick() + 5
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 2))
            RunService.Heartbeat:Wait()
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -2))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

-- REVERTED FARM ENGINE (Original Flow + Anchor)
task.spawn(function()
    while true do
        task.wait(0.1)
        if not running or smiting then continue end

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if hum and hum.Health > 0 and hrp then
            -- 1. Portal Jump
            local portal = Workspace.Lobby:FindFirstChild("Teleport2")
            if portal then
                char:PivotTo(portal.CFrame)
                task.wait(0.6)
            end

            local t = Players:FindFirstChild(targetName or "")
            local tHRP = t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")

            if tHRP and hrp.Parent then
                -- 2. Strike Position & Anchor
                hrp.Velocity = Vector3.zero
                char:PivotTo(tHRP.CFrame * CFrame.new(0, 1.5, -3))
                hrp.Anchored = true
                
                local timeout = tick() + 1.5
                repeat 
                    local rag = Workspace:FindFirstChild("bp1frms") and Workspace.bp1frms:FindFirstChild("Ragdolled")
                    if rag and rag.Value then 
                        sessionSlaps = sessionSlaps + 1
                        break 
                    end
                    RunService.Heartbeat:Wait()
                until tick() > timeout or not running
                
                -- 3. Reset Sequence
                hrp.Anchored = false
                forceReset()
                
                local respawnStart = tick()
                repeat task.wait() until player.Character ~= char or tick() - respawnStart > 3
                task.wait(0.2)
            end
        end
    end
end)

-- STEALTH HANDLER
RunService.Heartbeat:Connect(function()
    if not running and not smiting and hiding then
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - stealthPos).Magnitude > 150 then
            hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
        end
    end
end)

-- COMMANDS
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] then return end
    
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then 
        running = true 
        chatLog("Farm Re-Engaged.")
    elseif cmd == ".stop" then 
        running = false 
        chatLog("Farm Stopped.")
    elseif cmd == ".target" and args[2] then
        local p = findTarget(args[2])
        if p then targetName = p.Name chatLog("Targeting: "..p.Name) end
    elseif cmd == ".smite" and args[2] then
        local p = findTarget(args[2])
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".loopsmite" and args[2] then
        local p = findTarget(args[2])
        if p then loopsmiting = p.Name chatLog("Loop Smite: "..p.Name) end
    elseif cmd == ".unloopsmite" then 
        loopsmiting = nil 
    elseif cmd == ".addowner" and args[2] then
        local p = findTarget(args[2])
        if p then 
            owners[p.Name:lower()] = true 
            chatLog("Added Owner: "..p.Name)
        end
    elseif cmd == ".removeowner" and args[2] then
        local p = findTarget(args[2])
        if p and p.Name:lower() ~= primaryOwner:lower() then
            owners[p.Name:lower()] = nil
            chatLog("Removed Owner: "..p.Name)
        end
    elseif cmd == ".rj" then 
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then 
        forceReset()
    end
end

for _, p in pairs(Players:GetPlayers()) do
    p.Chatted:Connect(function(m) processChat(m, p) end)
end

Players.PlayerAdded:Connect(function(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end)

chatLog("Cipher Ultimate: Reverted Logic Ready.")
