-- Ensure the script doesn't hang if game loading is weird
task.wait(0.5)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- INITIAL STATE
local targetName = nil 
local running = false

-- THE COUNCIL (Permission List)
local owners = {
    ["rizalakasa"] = true
}

-- FEEDBACK SYSTEM (With Fallback)
local function chatLog(text)
    print("[Cipher]: " .. text) -- Always prints to F9 Console
    pcall(function()
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[Cipher Protocol]: " .. text;
            Color = Color3.fromRGB(255, 120, 0);
            Font = Enum.Font.SourceSansBold;
        })
    end)
end

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    local c = getCharacter(player)
    return c:WaitForChild("HumanoidRootPart", 5)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myHRP = getHRP(player)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(player)
                    if myHRP then myHRP.CFrame = CFrame.new(-1210, 328, 4) end
                    task.wait(0.4)

                    for i = 1, 5 do
                        if not running or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slappedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    end

                    if running and humanoid and humanoid.Parent then
                        humanoid.Health = 0
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    local sDisplay = speaker.DisplayName:lower()

    -- Permission Check
    if not owners[sName] and not owners[sDisplay] then return end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        if targetName then running = true chatLog("Bot Active.") else chatLog("Set target first.") end
    elseif cmd == ".stop" then
        running = false
        chatLog("Bot Stopped.")
    elseif cmd == ".target" and args[2] then
        local search = args[2]
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(search) or p.DisplayName:lower():find(search) then
                targetName = p.Name
                chatLog("Target: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        local search = args[2]
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(search) or p.DisplayName:lower():find(search) then
                owners[p.Name:lower()] = true
                chatLog("Added Owner: " .. p.Name)
                break
            end
        end
    elseif cmd == ".clearowners" then
        owners = {["rizalakasa"] = true}
        chatLog("Owners cleared to default.")
    end
end

-- HOOKS
local function connect(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end

for _, p in pairs(Players:GetPlayers()) do connect(p) end
Players.PlayerAdded:Connect(connect)

chatLog("System Online. Initial Owner: Rizalakasa")
