-- Cipher Protocol: High-Stability Base (Freeze Fix)
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

-- INITIAL STATE
local primaryOwners = {
    ["rizalakasa"] = true,
    ["ritzwitsplits"] = true
}
local targetName = nil 
local running = false
local slapDeath = true -- Default is ON
local owners = { 
    ["rizalakasa"] = true,
    ["ritzwitsplits"] = true 
}
local whitelist = { 
    ["rizalakasa"] = true,
    ["ritzwitsplits"] = true 
} 
local smiting = false
local loopsmiting = nil
local hiding = true
local sessionSlaps = 0
local startTime = tick()

-- STEALTH BASEPLATE
local stealthPos = Vector3.new(0, 10000, 0)
local function createStealthPlate()
    if Workspace:FindFirstChild("CipherStealthPlate") then return end
    local plate = Instance.new("Part")
    plate.Name = "CipherStealthPlate"
    plate.Size = Vector3.new(100, 1, 100)
    plate.Position = stealthPos
    plate.Anchored = true
    plate.Transparency = 1
    plate.Parent = Workspace
end
createStealthPlate()

-- AUTO-REJOIN ON KICK
game:GetService("GuiService").ErrorMessageChanged:Connect(function()
    task.wait(0.5)
    TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
end)

-- ANTI-AFK
for i,v in pairs(getconnections(player.Idled)) do v:Disable() end

local function chatLog(text) print("[Cipher]: " .. text) end

-- PRECISION FINDER
local function findTarget(name)
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower() == name or p.DisplayName:lower() == name then return p end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then return p end
    end
    return nil
end

-- AUTO-WHITE
local function checkAndWhite(p)
    if p == player then return end
    local nameLower = p.Name:lower()
    if p:IsFriendsWith(player.UserId) or primaryOwners[nameLower] then
        whitelist[nameLower] = true
    end
end
for _, p in pairs(Players:GetPlayers()) do checkAndWhite(p) end
Players.PlayerAdded:Connect(checkAndWhite)

local function forceReset()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    pcall(function()
        char:BreakJoints() 
        if hum then hum.Health = 0 end
    end)
end

-- COMBAT: SMITE ENGINE
local function executeSmite(targetP)
    if not targetP or not targetP.Character or whitelist[targetP.Name:lower()] or smiting then return end
    local tHRP = targetP.Character:FindFirstChild("HumanoidRootPart")
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    if tHRP and myHRP then
        smiting = true
        local flingLoop = RunService.Heartbeat:Connect(function()
            myHRP.Velocity = Vector3.new(50000, 50000, 50000)
        end)
        
        local strikeEnd = tick() + 5
        while tick() < strikeEnd and tHRP.Parent and myHRP.Parent do
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, 3))
            RunService.Heartbeat:Wait()
            myChar:PivotTo(tHRP.CFrame * CFrame.new(0, 2, -3))
            RunService.Heartbeat:Wait()
        end
        
        flingLoop:Disconnect()
        myHRP.Velocity = Vector3.zero
        myChar:PivotTo(CFrame.new(stealthPos + Vector3.new(0, 5, 0)))
        smiting = false
    end
end

-- MAIN ENGINE
task.spawn(function()
    while true do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if loopsmiting and not smiting then
            local t = Players:FindFirstChild(loopsmiting)
            if t then executeSmite(t) else loopsmiting = nil end
        elseif running and targetName and not smiting then
            pcall(function()
                if hum and hum.Health > 0 and hrp then
                    -- Reset position if in lobby to enter portal
                    if hrp.Position.Y > 500 then
                        hrp.CFrame = CFrame.new(-1210, 328, -8)
                        task.wait(0.4) 
                    end
                    
                    local t = Players:FindFirstChild(targetName)
                    local tHRP = t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                    local tHum = t and t.Character and t.Character:FindFirstChildOfClass("Humanoid")
                    
                    if tHRP and tHum and tHum.Health > 0 then
                        char:PivotTo(tHRP.CFrame * CFrame.new(0, 1.5, -3))
                        
                        local startW = tick()
                        local slashed = false
                        repeat 
                            local rag = Workspace:FindFirstChild("bp1frms") and Workspace.bp1frms:FindFirstChild("Ragdolled")
                            if (rag and rag.Value) or (tHRP.Velocity.Magnitude > 25) then
                                slashed = true
                                sessionSlaps = sessionSlaps + 1
                            end
                            RunService.Heartbeat:Wait()
                            -- If slapdeath is off, we keep teleporting to them until they die or time out
                            if not slapDeath and running and not smiting then
                                char:PivotTo(tHRP.CFrame * CFrame.new(0, 1.5, -3))
                            end
                        until (slapped and slapDeath) or tick() - startW > 1.5 or not running or tHum.Health <= 0
                        
                        -- Only reset if slapDeath is ON or the target actually died
                        if slapDeath or tHum.Health <= 0 then
                            forceReset()
                            repeat task.wait() until player.Character ~= char or not running
                            task.wait(0.2)
                        end
                    end
                end
            end)
        else
            if hiding and hrp and (hrp.Position - stealthPos).Magnitude > 100 and not smiting then
                hrp.CFrame = CFrame.new(stealthPos + Vector3.new(0, 5, 0))
            end
        end
        task.wait(0.01)
    end
end)

-- COMMAND HANDLER
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    if not owners[sName] and not owners[speaker.DisplayName:lower()] then return end
    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".farm" then running = true chatLog("Farm Engaged.")
    elseif cmd == ".stop" then running = false chatLog("Farm Stopped.")
    elseif cmd == ".slapdeath" then
        if args[2] == "on" then slapDeath = true chatLog("SlapDeath: ON")
        elseif args[2] == "off" then slapDeath = false chatLog("SlapDeath: OFF") end
    elseif cmd == ".target" and args[2] then
        local p = findTarget(args[2])
        if p then targetName = p.Name chatLog("Targeting: "..p.Name) end
    elseif cmd == ".smite" and args[2] then
        local p = findTarget(args[2])
        if p then task.spawn(executeSmite, p) end
    elseif cmd == ".loopsmite" and args[2] then
        local p = findTarget(args[2])
        if p then loopsmiting = p.Name chatLog("Loop Smite: "..p.Name) end
    elseif cmd == ".unloopsmite" then loopsmiting = nil
    elseif cmd == ".white" and args[2] then
        local p = findTarget(args[2])
        if p then whitelist[p.Name:lower()] = true chatLog("Whitelisted: "..p.Name) end
    elseif cmd == ".addowner" and args[2] then
        local p = findTarget(args[2])
        if p then owners[p.Name:lower()] = true chatLog("Owner Added: "..p.Name) end
    elseif cmd == ".removeowner" and args[2] then
        local p = findTarget(args[2])
        if p and not primaryOwners[p.Name:lower()] then 
            owners[p.Name:lower()] = nil 
            chatLog("Owner Removed: "..p.Name)
        else
            chatLog("Permission Denied: Primary Owner.")
        end
    elseif cmd == ".stats" then chatLog("Slaps: "..sessionSlaps.." | Uptime: "..math.floor(tick()-startTime).."s")
    elseif cmd == ".rj" then TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
    elseif cmd == ".reset" then forceReset()
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(m) processChat(m, p) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(m) processChat(m, p) end) end)

chatLog("Stability Fixed. Owners: Rizalakasa, RitzWitSplits. .slapdeath ready.")
