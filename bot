-- Stable Base with Aggressive Prediction
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- INITIAL STATE
local targetName = nil 
local running = false
local owners = {
    ["rizalakasa"] = true
}
local smiting = false

-- FEEDBACK SYSTEM
local function chatLog(text)
    print("[Cipher]: " .. text)
end

-- HELPER FUNCTIONS
local function getCharacter(plr)
    return plr.Character or plr.CharacterAdded:Wait()
end

local function getHRP(char)
    return char:WaitForChild("HumanoidRootPart", 5)
end

local function teleportToTarget()
    if not targetName then return false end
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return false end

    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local myChar = getCharacter(player)
    local myHRP = getHRP(myChar)
    
    if targetHRP and myHRP then
        myHRP.CFrame = targetHRP.CFrame + (targetHRP.CFrame.LookVector * 3)
        return true
    end
    return false
end

-- MAIN FARMING LOOP
task.spawn(function()
    while true do
        if running and targetName and not smiting then
            pcall(function()
                local char = getCharacter(player)
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                
                if humanoid and humanoid.Health > 0 then
                    local myHRP = getHRP(char)
                    if myHRP then myHRP.CFrame = CFrame.new(-1210, 328, 4) end
                    task.wait(0.4)

                    for i = 1, 5 do
                        if not running or smiting or teleportToTarget() then break end
                        task.wait(0.2)
                    end

                    local bp1frms = workspace:FindFirstChild("bp1frms")
                    local slashedVal = bp1frms and bp1frms:FindFirstChild("LastSlappedBy")

                    if slappedVal then
                        local timer = 0
                        while running and not smiting and slappedVal.Value ~= targetName and timer < 10 do
                            task.wait(0.1)
                            timer = timer + 0.1
                        end
                    else
                        task.wait(1)
                    end

                    if running and not smiting and humanoid and humanoid.Parent then
                        humanoid.Health = 0
                        player.CharacterAdded:Wait()
                        task.wait(0.5)
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- COMMAND LOGIC
local function processChat(msg, speaker)
    local sName = speaker.Name:lower()
    local sDisplay = speaker.DisplayName:lower()

    if not owners[sName] and not owners[sDisplay] then return end

    local args = string.split(msg:lower(), " ")
    local cmd = args[1]

    if cmd == ".start" then
        running = true chatLog("Started.")
    elseif cmd == ".stop" then
        running = false chatLog("Stopped.")
    elseif cmd == ".target" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                targetName = p.Name
                chatLog("Target: " .. targetName)
                break
            end
        end
    elseif cmd == ".addowner" and args[2] then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                owners[p.Name:lower()] = true
                chatLog("Added owner: " .. p.Name)
                break
            end
        end

    -- SMITE COMMAND WITH AGGRESSIVE PREDICTION
    elseif cmd == ".smite" and args[2] then
        local smiteTarget = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(args[2]) or p.DisplayName:lower():find(args[2]) then
                smiteTarget = p
                break
            end
        end
        
        if smiteTarget and smiteTarget.Character then
            task.spawn(function()
                smiting = true
                local char = getCharacter(player)
                local hrp = getHRP(char)
                local hum = char:FindFirstChildOfClass("Humanoid")
                
                local tChar = smiteTarget.Character
                local tHRP = tChar:FindFirstChild("HumanoidRootPart")
                local tHum = tChar:FindFirstChildOfClass("Humanoid")
                
                if hrp and tHRP and hum and tHum then
                    local originalPos = hrp.CFrame
                    chatLog("Smiting (Aggressive Prediction): " .. smiteTarget.Name)

                    hrp.CanCollide = false
                    hum:ChangeState(11)
                    
                    local flingLoop = RunService.Heartbeat:Connect(function()
                        local vel = hrp.Velocity
                        hrp.Velocity = vel * 99999999 + Vector3.new(0, 99999999, 0)
                        RunService.RenderStepped:Wait()
                        hrp.Velocity = vel
                        RunService.Stepped:Wait()
                        hrp.Velocity = vel + Vector3.new(0, 0.1, 0)
                    end)

                    local endTime = tick() + 4
                    while tick() < endTime do
                        if tHRP and tHRP.Parent then
                            -- AGGRESSIVE PREDICTION MATH:
                            -- Uses Velocity instead of MoveDirection for zero-delay tracking
                            -- Multiplier set to 0.22 (roughly 220ms lead)
                            local prediction = tHRP.Velocity * 0.22
                            
                            -- If they aren't moving, stay centered. If they are, lead them.
                            if tHRP.Velocity.Magnitude < 1 then
                                hrp.CFrame = tHRP.CFrame
                            else
                                hrp.CFrame = tHRP.CFrame + prediction
                            end
                        end
                        RunService.Heartbeat:Wait()
                    end

                    flingLoop:Disconnect()
                    hrp.Velocity = Vector3.zero
                    hrp.CFrame = originalPos
                    smiting = false
                    chatLog("Smite Finished.")
                end
            end)
        end
    end
end

-- HOOKS
local function connect(p)
    p.Chatted:Connect(function(m) processChat(m, p) end)
end

for _, p in pairs(Players:GetPlayers()) do connect(p) end
Players.PlayerAdded:Connect(connect)

chatLog("Cipher Active. High-Lead Smite Loaded.")
